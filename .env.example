# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="AQ.Ab8RN6JEqb-nwNdclUwd2dGZG_nzV9ibS7QSrr32ttbPmPjqvA"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ADMIN_PASSWORD: Safe decryption password to log in and manage Leads and AI Knowledge Base in the Admin Portal.
# Defaults to "shadowrootadmin123" if left blank.
ADMIN_PASSWORD="shadowrootadmin123"

# SUPABASE CONFIGURATION (CLIENT): Secure team authentication in the browser.
# These VITE_ vars are exposed to the frontend bundle — use the *anon* key only.
VITE_SUPABASE_URL="https://exovfiaalghyuslbhbnf.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"

# SUPABASE CONFIGURATION (SERVER): Durable data persistence on serverless hosts.
# Required on Vercel — the filesystem is read-only there, so leads/chats/knowledge
# are stored in Supabase instead. Run supabase/schema.sql once to create the tables.
# SUPABASE_URL defaults to VITE_SUPABASE_URL if omitted. The SERVICE ROLE key is
# secret — set it only as a server env var, NEVER prefixed with VITE_.
SUPABASE_URL="https://exovfiaalghyuslbhbnf.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# NVD_API_KEY (OPTIONAL): Raises the rate limit for the CVE Explorer tool.
# The /api/cve endpoint proxies the NIST National Vulnerability Database. Without
# a key NVD allows ~5 requests / 30s per IP; with one, ~50 / 30s. The tool works
# without it (it degrades to a "feed busy" message under throttling). Server-side
# only — never prefix with VITE_. Request a free key at:
# https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY="your-nvd-api-key"

